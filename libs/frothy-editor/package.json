{
  "name": "@frothy/editor",
  "version": "0.1.0",
  "private": true,
  "description": "CodeMirror 6 editor surface for Frothy, layered on @frothy/repl.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "tsc --noEmit && node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.5.0",
    "@codemirror/language": "^6.10.2",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.28.0",
    "@lezer/highlight": "^1.2.0",
    "@frothy/repl": "file:../frothy-repl"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.14.0",
    "jsdom": "^24.0.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  }
}
