# Original ESP32 dual-mode controller, restricted to the observer tranche.
CONFIG_BTDM_CTRL_MODE_BLE_ONLY=y
CONFIG_BTDM_CTRL_BLE_MAX_CONN=1
CONFIG_BTDM_BLE_SCAN_DUPL=y
CONFIG_BTDM_SCAN_DUPL_TYPE_DEVICE=y
CONFIG_BTDM_SCAN_DUPL_CACHE_SIZE=100
CONFIG_BTDM_SCAN_DUPL_CACHE_REFRESH_PERIOD=0

# Keep the observer stack inside the original ESP32's measured IRAM budget.
CONFIG_BTDM_CTRL_HLI=n
CONFIG_FREERTOS_PLACE_FUNCTIONS_INTO_FLASH=y
