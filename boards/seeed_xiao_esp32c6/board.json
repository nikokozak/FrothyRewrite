{
  "name": "Seeed Studio XIAO ESP32C6",
  "chip": "esp32c6",
  "target": "esp-idf",
  "profile": "esp32_plain",
  "peripherals": ["gpio", "adc", "uart", "pwm", "i2c", "trace", "pulse"],
  "pins": {
    "$led_builtin": 15,
    "$boot_button": 9,
    "$a0": 0,
