{
  "name": "frothy",
  "displayName": "Frothy",
  "description": "Per-line Frothy workflow inside VS Code: connect, send, see, save.",
  "version": "0.1.0",
  "publisher": "frothy",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      { "command": "frothy.connect",       "title": "Frothy: Connect" },
      { "command": "frothy.sendSelection", "title": "Frothy: Send Selection" },
      { "command": "frothy.sendFile",      "title": "Frothy: Send File" },
      { "command": "frothy.see",           "title": "Frothy: See" },
      { "command": "frothy.words",         "title": "Frothy: Words" },
      { "command": "frothy.save",          "title": "Frothy: Save" },
      { "command": "frothy.restore",       "title": "Frothy: Restore" },
      { "command": "frothy.interrupt",     "title": "Frothy: Interrupt" }
    ],
    "configuration": {
      "title": "Frothy",
      "properties": {
        "frothy.binaryPath": {
          "type": "string",
          "default": "frothy",
          "description": "Path to the frothy CLI. Absolute path or a name on PATH."
        },
        "frothy.port": {
          "type": "string",
          "default": "",
          "description": "Serial port for the Frothy device. Empty uses the CLI's port discovery."
        },
        "frothy.baud": {
          "type": "integer",
          "default": 115200,
          "description": "Serial baud rate."
        }
      }
    },
    "languages": [
      {
        "id": "frothy",
        "aliases": ["Frothy"],
        "extensions": [".frothy"]
      }
    ],
    "grammars": [
      {
        "language": "frothy",
        "scopeName": "source.frothy",
        "path": "./syntaxes/frothy.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "tsc --noEmit && esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --format=cjs --outfile=out/extension.js",
    "vscode:prepublish": "npm run build",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
