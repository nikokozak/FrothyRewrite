{
  "name": "frothy",
  "displayName": "Frothy",
  "description": "Live Frothy workflow inside VS Code: connect to a board, run forms and files, inspect words, save and restore.",
  "version": "0.4.0",
  "publisher": "NikolaiKozak",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nikokozak/FrothyRewrite.git",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/nikokozak/FrothyRewrite/tree/main/editors/vscode#readme",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:frothy"
  ],
  "contributes": {
    "languages": [
      {
        "id": "frothy",
        "aliases": ["Frothy"],
        "extensions": [".fr", ".frothy"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "frothy-transcript",
        "aliases": ["Frothy Transcript"],
        "mimetypes": ["text/x-frothy-transcript"]
      }
    ],
    "grammars": [
      {
        "language": "frothy",
        "scopeName": "source.frothy",
        "path": "./syntaxes/frothy.tmLanguage.json"
      },
      {
        "language": "frothy-transcript",
        "scopeName": "source.frothy.transcript",
        "path": "./syntaxes/frothy-transcript.tmLanguage.json"
      }
    ],
    "commands": [
      { "command": "frothy.connect",       "title": "Frothy: Connect",          "icon": "$(plug)" },
      { "command": "frothy.disconnect",    "title": "Frothy: Disconnect",       "icon": "$(debug-disconnect)" },
      { "command": "frothy.runForm",       "title": "Frothy: Run Form",         "icon": "$(play)" },
      { "command": "frothy.runFile",       "title": "Frothy: Run File",         "icon": "$(file-code)" },
      { "command": "frothy.rerun",         "title": "Frothy: Rerun",            "icon": "$(debug-rerun)" },
      { "command": "frothy.openExample",   "title": "Frothy: Open Example",     "icon": "$(book)" },
      { "command": "frothy.browseWords",   "title": "Frothy: Browse Words",     "icon": "$(list-unordered)" },
      { "command": "frothy.inspectWord",   "title": "Frothy: Inspect Word",     "icon": "$(symbol-field)" },
      { "command": "frothy.status",        "title": "Frothy: Show Status",     "icon": "$(info)" },
      { "command": "frothy.mem",           "title": "Frothy: Memory",          "icon": "$(graph)" },
      { "command": "frothy.save",          "title": "Frothy: Save Overlay",     "icon": "$(save)" },
      { "command": "frothy.restore",       "title": "Frothy: Restore Overlay",  "icon": "$(history)" },
      { "command": "frothy.interrupt",     "title": "Frothy: Interrupt",        "icon": "$(debug-stop)" },
      { "command": "frothy.showOutput",    "title": "Frothy: Show Output",      "icon": "$(terminal)" }
    ],
    "keybindings": [
      { "command": "frothy.runForm",       "key": "ctrl+enter",       "mac": "cmd+enter",      "when": "editorTextFocus && editorLangId == frothy && frothy.isConnected && !frothy.isBusy" },
      { "command": "frothy.runFile",       "key": "ctrl+shift+enter", "mac": "cmd+shift+enter", "when": "editorTextFocus && editorLangId == frothy && frothy.isConnected && !frothy.isBusy" },
      { "command": "frothy.rerun",         "key": "ctrl+alt+r",       "mac": "cmd+alt+r",      "when": "editorTextFocus && editorLangId == frothy && frothy.isConnected && !frothy.isBusy && frothy.hasLastForm" },
      { "command": "frothy.interrupt",     "key": "ctrl+alt+.",       "mac": "cmd+alt+.",     "when": "frothy.isConnected && frothy.isBusy" }
    ],
    "menus": {
      "editor/title": [
        { "command": "frothy.runForm",       "when": "editorLangId == frothy && frothy.isConnected && !frothy.isBusy", "group": "navigation@1" },
        { "command": "frothy.interrupt",     "when": "editorLangId == frothy && frothy.isConnected && frothy.isBusy",  "group": "navigation@1" }
      ],
      "editor/context": [
        { "command": "frothy.runForm",       "when": "editorLangId == frothy && frothy.isConnected && !frothy.isBusy", "group": "frothy@1" },
        { "command": "frothy.runFile",       "when": "editorLangId == frothy && frothy.isConnected && !frothy.isBusy", "group": "frothy@2" },
        { "command": "frothy.rerun",         "when": "editorLangId == frothy && frothy.isConnected && !frothy.isBusy && frothy.hasLastForm", "group": "frothy@3" },
        { "command": "frothy.inspectWord",   "when": "editorLangId == frothy && frothy.isConnected && !frothy.isBusy", "group": "frothy@4" }
      ],
      "commandPalette": [
        { "command": "frothy.runForm",       "when": "editorLangId == frothy && frothy.isConnected && !frothy.isBusy" },
        { "command": "frothy.runFile",       "when": "editorLangId == frothy && frothy.isConnected && !frothy.isBusy" },
        { "command": "frothy.rerun",         "when": "frothy.isConnected && !frothy.isBusy && frothy.hasLastForm" },
        { "command": "frothy.openExample" },
        { "command": "frothy.browseWords",   "when": "frothy.isConnected && !frothy.isBusy" },
        { "command": "frothy.inspectWord",   "when": "editorLangId == frothy && frothy.isConnected && !frothy.isBusy" },
        { "command": "frothy.disconnect",    "when": "frothy.isConnected" },
        { "command": "frothy.interrupt",     "when": "frothy.isConnected && frothy.isBusy" }
      ]
    },
    "configuration": {
      "title": "Frothy",
      "properties": {
        "frothy.binaryPath": {
          "type": "string",
          "default": "frothy",
          "description": "Path to the frothy CLI. Absolute path or a name on PATH."
        },
        "frothy.port": {
          "type": "string",
          "default": "",
          "description": "Serial port for the Frothy device. Empty asks the CLI to auto-discover."
        },
        "frothy.baud": {
          "type": "integer",
          "default": 115200,
          "description": "Serial baud rate."
        },
        "frothy.autoConnect": {
          "type": "boolean",
          "default": false,
          "description": "Connect automatically when a Frothy file is opened."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc --noEmit && esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --format=cjs --outfile=out/extension.js",
    "test": "npm run test:unit",
    "test:unit": "esbuild test/session-records.test.ts test/forms.test.ts --bundle --platform=node --target=node18 --format=cjs --outdir=out/test && node --test out/test/session-records.test.js out/test/forms.test.js",
    "posttest": "node -e \"require('node:fs').rmSync('out/test', { recursive: true, force: true })\"",
    "vscode:prepublish": "npm run build",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
